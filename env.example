# ===== CONFIGURACIÓN DE VERCEL PARA PHRONENCIAL =====

# Autenticación (NextAuth.js)
NEXTAUTH_URL=https://tu-dominio.vercel.app
NEXTAUTH_SECRET=tu-secret-key-aqui

# Google OAuth (para login con Google)
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-tu-client-secret

# Asignación automática de roles (opcional)
# Lista de emails separados por comas que recibirán rol ADMIN automáticamente
# Ejemplo: ADMIN_EMAILS=admin@phorencial.com,manager@phorencial.com
ADMIN_EMAILS=

# Emails permitidos para registro automático (opcional)
# Si está configurada, solo estos emails pueden registrarse automáticamente al iniciar sesión con Google
# Si NO está configurada, solo usuarios existentes en la base de datos pueden acceder
# Ejemplo: ALLOWED_EMAILS=nuevo@phorencial.com,otro@phorencial.com
# IMPORTANTE: Si no configuras esta variable, el sistema solo permitirá acceso a usuarios que ya existen en la base de datos
ALLOWED_EMAILS=

# Supabase Database
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui
# También puedes usar estas variables alternativas:
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=tu-service-role-key-aqui

# ----- WhatsApp / Uchat / ManyChat -----
# Webhook público (formularios, Uchat → CRM): token para autorizar POST
ALLOWED_WEBHOOK_TOKEN=tu-webhook-token-aqui
WEBHOOK_TOKEN=tu-webhook-token-aqui

# WhatsApp Business API (Meta) – para webhook directo o envío desde CRM
# Ver docs/WHATSAPP-BUSINESS-API-OFICIAL.md y docs/UCHAT-SETUP.md
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_VERIFY_TOKEN=tu-token-de-verificacion-personalizado
WHATSAPP_APP_SECRET=tu-app-secret
WHATSAPP_TOKEN=tu-whatsapp-token-aqui

# Uchat – flujos, bots, integración con CRM (ver docs/UCHAT-SETUP.md)
USE_UCHAT=false
UCHAT_API_KEY=
UCHAT_WEBHOOK_SECRET=
# Inbound Webhook: cuando el webhook de Meta apunta al CRM, el CRM reenvía "Solicitud de Crédito" aquí para que UChat ejecute el flujo (Opción B)
UCHAT_INBOUND_WEBHOOK_SOLICITUD_CREDITO_URL=
# Inbound Webhook "lead-nuevo": al recibir el primer mensaje de un lead (sin etiqueta lead-nuevo), el CRM llama aquí para que UChat envíe el mensaje de bienvenida
UCHAT_INBOUND_WEBHOOK_LEAD_NUEVO_URL=
# Inbound Webhook "Consultas - Carla": para mensajes que no son "Solicitud de Crédito", el CRM reenvía aquí para que Carla (AI Agent) responda con la base de conocimiento
UCHAT_INBOUND_WEBHOOK_CONSULTAS_CARLA_URL=
# Pipeline ventas → Uchat (etiqueta en suscriptor). El CRM también envía WhatsApp (Meta) salvo PIPELINE_NOTIFY_SKIP_META=true
UCHAT_INBOUND_WEBHOOK_PREAPROBADO_URL=
UCHAT_INBOUND_WEBHOOK_RECHAZADO_URL=
# true = no enviar WhatsApp desde CRM al pasar a preaprobado/rechazado (solo Uchat debe enviar usando "message" del webhook)
# PIPELINE_NOTIFY_SKIP_META=false
# Plantillas Meta (obligatorias para enviar después de 24 h sin mensaje del cliente). Cuerpo con exactamente {{1}} = texto completo.
# WHATSAPP_TEMPLATE_PIPELINE_NOTIFY=nombre_plantilla_generica
# Opcional: solo Chats (vendedor); si no se define, se usa WHATSAPP_TEMPLATE_PIPELINE_NOTIFY
# WHATSAPP_TEMPLATE_CHAT_REENGAGEMENT=
# WHATSAPP_TEMPLATE_PREAPROBADO=nombre_plantilla_preaprobado
# WHATSAPP_TEMPLATE_RECHAZADO=nombre_plantilla_rechazado
# WHATSAPP_TEMPLATE_PIPELINE_LANG=es
# Nombre exacto de la variable del CUERPO en Meta (sin llaves), ej. plantilla con {{mensaje_pipeline}}:
# WHATSAPP_TEMPLATE_BODY_PARAMETER_NAME=mensaje_pipeline

# Sentry (Opcional)
SENTRY_ORG=tu-org
SENTRY_PROJECT=tu-proyecto
SENTRY_AUTH_TOKEN=tu-sentry-token

# Redis (Opcional - para cache)
REDIS_URL=redis://localhost:6379

# Google Maps API (Opcional - para mapa de concesionarias)
# API key pública para Maps JavaScript API y Places Autocomplete (frontend)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=tu-google-maps-api-key-publica
# API key privada para Geocoding API y Places API (server-side)
GOOGLE_MAPS_API_KEY=tu-google-maps-api-key-privada

# ===== INSTRUCCIONES DE CONFIGURACIÓN =====
# 1. Copia este archivo como .env.local
# 2. Reemplaza todos los valores con los datos reales de tu proyecto
# 3. En Vercel, agrega estas variables en Settings > Environment Variables
# 4. Asegúrate de marcar como sensibles las que contienen secrets/tokens
